# Chave da API Anthropic (obtenha em https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Conta Gmail que enviará o e-mail (precisa ter App Password habilitado)
# Ative em: Conta Google → Segurança → Senhas de app
GMAIL_USER=seu.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Destinatário da nota técnica
RECIPIENT_EMAIL=destinatario@email.com

# Inlabs API — fallback quando Planalto estiver bloqueado (ex: GitHub Actions)
# Cadastro GRATUITO em: https://inlabs.in.gov.br/acesso
INLABS_EMAIL=seu@email.com
INLABS_PASSWORD=sua_senha_inlabs

# Enviar e-mail mesmo quando não houver MP publicada no dia? (true/false)
NOTIFY_IF_EMPTY=false

# Horário de execução automática no modo --schedule (formato HH:MM)
SCHEDULE_TIME=08:00

# Ativar pesquisa de contexto via web search antes de gerar a nota (recomendado: true)
ENABLE_WEB_SEARCH=true
